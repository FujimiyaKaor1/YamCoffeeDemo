page {
  background-color: #FFF3E0;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 26rpx;
  color: #333333;
  box-sizing: border-box;
}

.container {
  padding: 24rpx;
}

.btn-primary {
  background-color: #FF6D00;
  color: #ffffff;
  border-radius: 8rpx;
  font-size: 28rpx;
  padding: 20rpx 40rpx;
  text-align: center;
}

.btn-primary:active {
  background-color: #E65100;
}

.btn-secondary {
  background-color: #ffffff;
  color: #FF6D00;
  border: 2rpx solid #FF6D00;
  border-radius: 8rpx;
  font-size: 28rpx;
  padding: 20rpx 40rpx;
  text-align: center;
}

.btn-disabled {
  background-color: #E5E5E5;
  color: #999999;
  border-radius: 8rpx;
  font-size: 28rpx;
  padding: 20rpx 40rpx;
  text-align: center;
}

.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.text-primary {
  color: #FF6D00;
}

.text-dark {
  color: #1A1A1A;
}

.text-gray {
  color: #999999;
}

.text-price {
  color: #FF6D00;
  font-weight: 600;
}

.text-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.text-subtitle {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
}

.text-body {
  font-size: 26rpx;
  color: #333333;
}

.text-small {
  font-size: 24rpx;
  color: #666666;
}

.flex {
  display: flex;
}

.flex-column {
  flex-direction: column;
}

.flex-center {
  justify-content: center;
  align-items: center;
}

.flex-between {
  justify-content: space-between;
  align-items: center;
}

.flex-wrap {
  flex-wrap: wrap;
}

.flex-1 {
  flex: 1;
}

.mt-10 {
  margin-top: 10rpx;
}

.mt-20 {
  margin-top: 20rpx;
}

.mt-30 {
  margin-top: 30rpx;
}

.mb-10 {
  margin-bottom: 10rpx;
}

.mb-20 {
  margin-bottom: 20rpx;
}

.mb-30 {
  margin-bottom: 30rpx;
}

.ml-10 {
  margin-left: 10rpx;
}

.ml-20 {
  margin-left: 20rpx;
}

.mr-10 {
  margin-right: 10rpx;
}

.mr-20 {
  margin-right: 20rpx;
}

.p-20 {
  padding: 20rpx;
}

.p-30 {
  padding: 30rpx;
}

.divider {
  height: 1rpx;
  background-color: #E5E5E5;
  margin: 20rpx 0;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
}

.empty-state text {
  color: #999999;
  font-size: 28rpx;
}

.safe-area-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}
