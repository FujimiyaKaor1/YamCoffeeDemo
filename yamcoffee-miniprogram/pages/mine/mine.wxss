.container {
  min-height: 100vh;
  background-color: #F5F5F5;
}

.user-section {
  background: linear-gradient(135deg, #FF6D00 0%, #FF9100 100%);
  padding: 60rpx 24rpx 40rpx;
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid #ffffff;
}

.user-text {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
}

.phone {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
}

.arrow {
  width: 32rpx;
  height: 32rpx;
}

.order-section {
  background-color: #ffffff;
  margin: 24rpx;
  border-radius: 16rpx;
  padding: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.section-more {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #999999;
}

.arrow-small {
  width: 24rpx;
  height: 24rpx;
  margin-left: 8rpx;
}

.order-tabs {
  display: flex;
  justify-content: space-around;
}

.order-tab {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.tab-icon-wrapper {
  position: relative;
  width: 64rpx;
  height: 64rpx;
}

.tab-icon {
  width: 64rpx;
  height: 64rpx;
}

.badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  padding: 0 8rpx;
  background-color: #FF6D00;
  color: #ffffff;
  font-size: 20rpx;
  text-align: center;
  border-radius: 16rpx;
}

.tab-text {
  font-size: 24rpx;
  color: #666666;
  margin-top: 12rpx;
}

.menu-section {
  background-color: #ffffff;
  margin: 24rpx;
  border-radius: 16rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  width: 44rpx;
  height: 44rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

.logout-section {
  padding: 60rpx 24rpx;
}

.logout-btn {
  background-color: #ffffff;
  text-align: center;
  padding: 28rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #F44336;
}
