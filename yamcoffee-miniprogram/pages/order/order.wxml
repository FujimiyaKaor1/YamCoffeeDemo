<view class="container">
  <view class="tabs">
    <view class="tab-item {{currentTab === item.key ? 'active' : ''}}" 
          wx:for="{{tabs}}" wx:key="key" 
          bindtap="onTabChange" data-index="{{index}}">
      <text>{{item.name}}</text>
    </view>
  </view>

  <view class="order-list" wx:if="{{orders.length > 0}}">
    <view class="order-card" wx:for="{{orders}}" wx:key="id" bindtap="onOrderTap" data-order="{{item}}">
      <view class="order-header">
        <text class="order-no">订单号: {{item.orderNo}}</text>
        <text class="order-status status-{{item.status}}">{{item.statusText}}</text>
      </view>
      
      <view class="order-items">
        <view class="order-item" wx:for="{{item.items}}" wx:key="id" wx:for-item="product">
          <image class="item-image" src="{{product.productImage}}" mode="aspectFill"></image>
          <view class="item-info">
            <text class="item-name">{{product.productName}}</text>
            <view class="item-price-row">
              <text class="item-price">¥{{product.productPrice}}</text>
              <text class="item-quantity">x{{product.quantity}}</text>
            </view>
          </view>
        </view>
      </view>
      
      <view class="order-footer">
        <view class="order-total">
          <text>共{{item.itemCount}}件商品</text>
          <text class="total-price">实付: <text class="price">¥{{item.payAmount}}</text></text>
        </view>
        <view class="order-actions" catchtap="true">
          <view class="btn-cancel" wx:if="{{item.status === 0}}" catchtap="onCancelOrder" data-order="{{item}}">取消订单</view>
          <view class="btn-primary" wx:if="{{item.status === 0}}" catchtap="onPay" data-order="{{item}}">去支付</view>
          <view class="btn-primary" wx:if="{{item.status === 2}}" catchtap="onConfirmReceive" data-order="{{item}}">确认收货</view>
        </view>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:if="{{!loading && orders.length === 0}}">
    <image src="/images/common/empty-order.png" mode="aspectFit"></image>
    <text>暂无订单</text>
  </view>
</view>
