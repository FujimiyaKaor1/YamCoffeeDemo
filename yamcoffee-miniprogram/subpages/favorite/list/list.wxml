<view class="container">
  <view class="product-grid" wx:if="{{favorites.length > 0}}">
    <view class="product-card" wx:for="{{favorites}}" wx:key="id"
          bindtap="onProductTap" data-product="{{item}}">
      <image class="product-image" src="{{item.mainImage}}" mode="aspectFill"></image>
      <view class="product-info">
        <text class="product-name">{{item.name}}</text>
        <text class="product-subtitle">{{item.subtitle}}</text>
        <view class="product-price-row">
          <text class="product-price">¥{{item.price}}</text>
          <view class="btn-remove" catchtap="onRemoveFavorite" data-id="{{item.id}}">取消收藏</view>
        </view>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:if="{{!loading && favorites.length === 0}}">
    <image src="/images/common/empty-favorite.png" mode="aspectFit"></image>
    <text>暂无收藏</text>
    <view class="btn-go-shopping" bindtap="wx.switchTab" data-url="/pages/index/index">去逛逛</view>
  </view>
</view>
