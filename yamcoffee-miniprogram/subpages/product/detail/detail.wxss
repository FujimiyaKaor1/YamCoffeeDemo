.container {
  padding-bottom: 120rpx;
}

.product-swiper {
  width: 100%;
  height: 750rpx;
}

.product-image {
  width: 100%;
  height: 100%;
}

.product-info {
  background-color: #ffffff;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.price-row {
  display: flex;
  align-items: baseline;
  margin-bottom: 16rpx;
}

.price {
  font-size: 48rpx;
  font-weight: 700;
  color: #FF6D00;
}

.original-price {
  font-size: 28rpx;
  color: #999999;
  text-decoration: line-through;
  margin-left: 16rpx;
}

.product-name {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 12rpx;
}

.product-subtitle {
  display: block;
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 16rpx;
}

.product-tags {
  display: flex;
  margin-bottom: 16rpx;
}

.tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  margin-right: 12rpx;
}

.tag.hot {
  background-color: #FFF3E0;
  color: #FF6D00;
}

.tag.new {
  background-color: #E3F2FD;
  color: #2196F3;
}

.product-meta {
  display: flex;
  font-size: 24rpx;
  color: #999999;
}

.product-meta text:first-child {
  margin-right: 24rpx;
}

.quantity-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: #ffffff;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.section-label {
  font-size: 28rpx;
  color: #333333;
}

.quantity-control {
  display: flex;
  align-items: center;
}

.btn-minus, .btn-plus {
  width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  font-size: 36rpx;
  color: #333333;
  background-color: #F5F5F5;
  border-radius: 8rpx;
}

.btn-minus.disabled, .btn-plus.disabled {
  color: #CCCCCC;
}

.quantity-input {
  width: 80rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  font-size: 28rpx;
  margin: 0 16rpx;
  background-color: #F5F5F5;
  border-radius: 8rpx;
}

.footer-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  background-color: #ffffff;
  padding: 16rpx 24rpx;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.action-icons {
  display: flex;
  margin-right: 24rpx;
}

.action-icon {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 20rpx;
}

.action-icon image {
  width: 44rpx;
  height: 44rpx;
}

.action-icon text {
  font-size: 20rpx;
  color: #666666;
  margin-top: 4rpx;
}

.action-buttons {
  flex: 1;
  display: flex;
}

.btn-cart {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 28rpx;
  color: #FF6D00;
  background-color: #FFF3E0;
  border-radius: 40rpx 0 0 40rpx;
}

.btn-buy {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 28rpx;
  color: #ffffff;
  background-color: #FF6D00;
  border-radius: 0 40rpx 40rpx 0;
}

.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
  color: #999999;
}
