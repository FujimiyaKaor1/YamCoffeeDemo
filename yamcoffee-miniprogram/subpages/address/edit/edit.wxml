<view class="container">
  <view class="form-section">
    <view class="form-item">
      <text class="label">收货人</text>
      <input class="input" placeholder="请输入收货人姓名" value="{{form.receiverName}}" 
             data-field="receiverName" bindinput="onInputChange" />
    </view>
    <view class="form-item">
      <text class="label">手机号</text>
      <input class="input" type="number" placeholder="请输入手机号" value="{{form.receiverPhone}}" 
             data-field="receiverPhone" bindinput="onInputChange" maxlength="11" />
    </view>
    <view class="form-item">
      <text class="label">所在地区</text>
      <picker mode="region" value="{{region}}" bindchange="onRegionChange">
        <view class="picker">
          <text class="{{region.length > 0 ? '' : 'placeholder'}}">
            {{region.length > 0 ? region.join('') : '请选择省市区'}}
          </text>
          <image class="arrow" src="/images/icons/arrow-right.png" mode="aspectFit"></image>
        </view>
      </picker>
    </view>
    <view class="form-item">
      <text class="label">详细地址</text>
      <textarea class="textarea" placeholder="请输入详细地址" value="{{form.detailAddress}}" 
                data-field="detailAddress" bindinput="onInputChange" maxlength="200" />
    </view>
  </view>

  <view class="default-section">
    <text class="label">设为默认地址</text>
    <switch checked="{{form.isDefault}}" color="#FF6D00" bindchange="onDefaultChange" />
  </view>

  <view class="submit-section">
    <button class="btn-submit" bindtap="onSubmit">保存地址</button>
  </view>
</view>
