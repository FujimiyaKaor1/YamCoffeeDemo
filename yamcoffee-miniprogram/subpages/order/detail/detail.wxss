.container {
  min-height: 100vh;
  background-color: #F5F5F5;
  padding-bottom: 120rpx;
}

.status-section {
  background: linear-gradient(135deg, #FF6D00 0%, #FF9100 100%);
  padding: 48rpx 24rpx;
  color: #ffffff;
}

.status-text {
  font-size: 36rpx;
  font-weight: 600;
}

.status-tip {
  display: block;
  font-size: 26rpx;
  margin-top: 12rpx;
  opacity: 0.8;
}

.address-section {
  display: flex;
  background-color: #ffffff;
  padding: 24rpx;
  margin: 24rpx;
  border-radius: 16rpx;
}

.address-icon {
  margin-right: 16rpx;
}

.address-icon image {
  width: 40rpx;
  height: 40rpx;
}

.address-content {
  flex: 1;
}

.address-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.phone {
  font-size: 28rpx;
  color: #666666;
  margin-left: 24rpx;
}

.address-text {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.5;
}

.product-section {
  background-color: #ffffff;
  margin: 24rpx;
  padding: 24rpx;
  border-radius: 16rpx;
}

.section-header {
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.product-item {
  display: flex;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.product-item:last-child {
  border-bottom: none;
}

.product-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
}

.product-info {
  flex: 1;
}

.product-name {
  font-size: 28rpx;
  color: #333333;
}

.product-price-row {
  display: flex;
  justify-content: space-between;
  margin-top: 20rpx;
}

.product-price {
  font-size: 28rpx;
  color: #FF6D00;
}

.product-quantity {
  font-size: 26rpx;
  color: #999999;
}

.info-section {
  background-color: #ffffff;
  margin: 24rpx;
  padding: 24rpx;
  border-radius: 16rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
}

.info-label {
  font-size: 26rpx;
  color: #999999;
}

.info-value {
  font-size: 26rpx;
  color: #333333;
  display: flex;
  align-items: center;
}

.copy-btn {
  font-size: 24rpx;
  color: #FF6D00;
  margin-left: 16rpx;
  padding: 4rpx 12rpx;
  border: 1rpx solid #FF6D00;
  border-radius: 4rpx;
}

.summary-section {
  background-color: #ffffff;
  margin: 24rpx;
  padding: 24rpx;
  border-radius: 16rpx;
}

.summary-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  font-size: 26rpx;
  color: #666666;
}

.summary-row .discount {
  color: #4CAF50;
}

.summary-row.total {
  border-top: 1rpx solid #F5F5F5;
  padding-top: 20rpx;
  margin-top: 12rpx;
}

.total-price {
  font-size: 32rpx;
  font-weight: 600;
  color: #FF6D00;
}

.footer-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
  background-color: #ffffff;
  padding: 16rpx 24rpx;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.btn-cancel {
  padding: 16rpx 32rpx;
  font-size: 28rpx;
  color: #666666;
  border: 1rpx solid #E5E5E5;
  border-radius: 40rpx;
}

.btn-primary {
  padding: 16rpx 32rpx;
  font-size: 28rpx;
  color: #ffffff;
  background-color: #FF6D00;
  border-radius: 40rpx;
}

.btn-confirm-payment {
  padding: 16rpx 32rpx;
  font-size: 28rpx;
  color: #ffffff;
  background-color: #FF9800;
  border-radius: 40rpx;
}
