.container {
  min-height: 100vh;
  background-color: #F5F5F5;
  padding-bottom: 120rpx;
}

.cart-list {
  padding: 24rpx;
}

.cart-item {
  display: flex;
  align-items: center;
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.checkbox {
  padding: 20rpx;
}

.checkbox-inner {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #CCCCCC;
  border-radius: 50%;
  position: relative;
}

.checkbox-inner.checked {
  background-color: #FF6D00;
  border-color: #FF6D00;
}

.checkbox-inner.checked::after {
  content: '';
  position: absolute;
  left: 12rpx;
  top: 6rpx;
  width: 12rpx;
  height: 24rpx;
  border: 2rpx solid #ffffff;
  border-top: none;
  border-left: none;
  transform: rotate(45deg);
}

.product-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
}

.product-info {
  flex: 1;
  margin-left: 20rpx;
}

.product-name {
  font-size: 28rpx;
  color: #333333;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.price-row {
  margin-top: 12rpx;
}

.product-price {
  font-size: 32rpx;
  font-weight: 600;
  color: #FF6D00;
}

.quantity-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
}

.quantity-control {
  display: flex;
  align-items: center;
}

.btn-minus, .btn-plus {
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  font-size: 32rpx;
  color: #333333;
  background-color: #F5F5F5;
  border-radius: 8rpx;
}

.btn-minus.disabled, .btn-plus.disabled {
  color: #CCCCCC;
}

.quantity-text {
  width: 60rpx;
  text-align: center;
  font-size: 28rpx;
}

.btn-delete {
  font-size: 24rpx;
  color: #999999;
  padding: 8rpx 16rpx;
}

.footer-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  background-color: #ffffff;
  padding: 16rpx 24rpx;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.select-all {
  display: flex;
  align-items: center;
}

.select-all text {
  font-size: 26rpx;
  color: #333333;
  margin-left: 8rpx;
}

.checkout-info {
  flex: 1;
  text-align: right;
  margin-right: 20rpx;
}

.total-label {
  font-size: 26rpx;
  color: #333333;
}

.total-price {
  font-size: 36rpx;
  font-weight: 600;
  color: #FF6D00;
}

.btn-checkout {
  background-color: #FF6D00;
  color: #ffffff;
  font-size: 28rpx;
  padding: 20rpx 40rpx;
  border-radius: 40rpx;
}

.btn-checkout.disabled {
  background-color: #CCCCCC;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
}

.empty-state text {
  font-size: 28rpx;
  color: #999999;
  margin-top: 20rpx;
}

.btn-go-shopping {
  margin-top: 30rpx;
  background-color: #FF6D00;
  color: #ffffff;
  font-size: 28rpx;
  padding: 16rpx 40rpx;
  border-radius: 32rpx;
}
